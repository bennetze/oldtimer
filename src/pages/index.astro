---
import Layout from '../layouts/Layout.astro';
import SiteChrome from '../components/SiteChrome.astro';
import craftHands from '../assets/oldtimer/craft-hands.png';
import exploreKaufen from '../assets/oldtimer/explore-kaufen.png';
import exploreKontakt from '../assets/oldtimer/explore-kontakt.png';
import exploreUeberUns from '../assets/oldtimer/explore-ueber-uns.png';
import heroSiteVideo from '../assets/oldtimer/hero-site.webm';
import projekteImage from '../assets/oldtimer/L1005735.webp';
import restaurierungImage from '../assets/oldtimer/L1005787.webp';

const exploreItems = [
	{
		number: '01',
		title: 'Über uns',
		text: 'Ein Atelier für seltene Automobile, in dem Erfahrung, Diskretion und handwerkliche Ruhe zusammenfinden.',
		image: exploreUeberUns,
		href: '/#explore',
	},
	{
		number: '02',
		title: 'Projekte',
		text: 'Ausgewählte Restaurierungen mit dokumentierter Substanz, technischer Tiefe und einem Blick für bleibenden Wert.',
		image: projekteImage,
		href: '/#explore',
	},
	{
		number: '03',
		title: 'Handwerk',
		text: 'Karosserie, Technik und Interieur werden mit Sorgfalt behandelt, damit Originalität und Fahrbarkeit erhalten bleiben.',
		image: restaurierungImage,
		href: '/#explore',
	},
	{
		number: '04',
		title: 'Oldtimer kaufen',
		text: 'Begleitung beim Erwerb außergewöhnlicher Klassiker mit Prüfung von Herkunft, Historie und Erhaltungsqualität.',
		image: exploreKaufen,
		href: '/#explore',
	},
	{
		number: '05',
		title: 'Kontakt',
		text: 'Ein persönliches Gespräch über Restaurierung, Werterhalt und die nächste Etappe Ihres Fahrzeugs.',
		image: exploreKontakt,
		href: '/#explore',
	},
];
---

<Layout>
	<SiteChrome>
		<main>
			<nav class="section-indicator" aria-label="Abschnitte" data-section-indicator>
				<button class="section-indicator__dot is-active" type="button" data-section-target="#start" data-scroll-target="#start">
					<span>Start</span>
				</button>
				<button class="section-indicator__dot" type="button" data-section-target="#handwerk" data-scroll-target="#handwerk">
					<span>Handwerk</span>
				</button>
				<button class="section-indicator__dot" type="button" data-section-target="#explore" data-scroll-target="#explore">
					<span>Erkunden</span>
				</button>
			</nav>

			<section class="media-panel hero" id="start" aria-labelledby="hero-title">
				<video
					class="media-panel__image"
					src={heroSiteVideo}
					autoplay
					muted
					loop
					playsinline
					preload="auto"
					aria-label="Klassischer Oldtimer in einer modernen Restaurierungswerkstatt"
				></video>
				<div class="media-panel__shade"></div>
				<div class="media-panel__content media-panel__content--hero">
					<h1 id="hero-title">Wir restaurieren keine Oldtimer, wir bewahren Geschichte.</h1>
					<button class="scroll-cue" type="button" data-scroll-target="#handwerk" aria-label="Zum Handwerk scrollen">
						<span aria-hidden="true"></span>
					</button>
				</div>
			</section>

			<section class="media-panel craft" id="handwerk" aria-labelledby="craft-title">
				<img
					class="media-panel__image"
					src={craftHands.src}
					alt="Hände arbeiten präzise an einem Bauteil eines Oldtimers"
					loading="lazy"
				/>
				<div class="media-panel__shade media-panel__shade--craft"></div>
				<div class="media-panel__content media-panel__content--craft">
					<h2 id="craft-title">Handwerk, Geduld und Präzision für Fahrzeuge mit Seele.</h2>
					<button class="scroll-cue scroll-cue--craft" type="button" data-scroll-target="#explore" aria-label="Alles erkunden">
						<span aria-hidden="true"></span>
					</button>
				</div>
			</section>

			<section class="explore" id="explore" aria-labelledby="explore-title">
				<div class="explore__intro">
					<p class="kicker kicker--dark">Setzen Sie Ihre Reise fort</p>
					<h2 id="explore-title">Alles Erkunden</h2>
				</div>
				<div class="explore-grid">
					{
						exploreItems.map((item) => (
							<a class="explore-card" href={item.href}>
								<span class="explore-card__image" aria-hidden="true">
									<img src={item.image.src} alt="" loading="lazy" />
								</span>
								<span class="explore-card__body">
									<span class="explore-card__meta">
										<span>{item.number}</span>
										<span aria-hidden="true"></span>
									</span>
									<strong>{item.title}</strong>
									<span class="explore-card__text">{item.text}</span>
								</span>
							</a>
						))
					}
				</div>
			</section>
		</main>

		<script is:inline>
			const heroVideo = document.querySelector('.hero video');

			const playHeroVideo = () => {
				if (!(heroVideo instanceof HTMLVideoElement)) {
					return;
				}

				heroVideo.muted = true;
				heroVideo.defaultMuted = true;
				heroVideo.playsInline = true;
				heroVideo.play().catch(() => {
					/* Safari may block autoplay depending on user/site policy. */
				});
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', playHeroVideo, { once: true });
			} else {
				playHeroVideo();
			}

			window.addEventListener('pageshow', playHeroVideo);
		</script>
	</SiteChrome>
</Layout>


<style>
	:global(html),
	:global(body),
	main {
		background: #101010;
		background-color: #101010;
	}

	.scroll-cue {
		color: currentColor;
		background: transparent;
		border: 0;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.24em;
		font-size: 0.66rem;
		font-weight: 500;
	}

	.scroll-cue {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.8rem;
	}

	.media-panel {
		position: relative;
		display: grid;
		min-height: 100vh;
		overflow: hidden;
		isolation: isolate;
	}

	.media-panel::after {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: -1;
		height: 18vh;
		background: linear-gradient(180deg, rgba(16, 16, 16, 0), #101010);
		content: '';
		pointer-events: none;
	}

	.media-panel__image,
	.media-panel__shade {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.media-panel__image {
		z-index: -2;
		object-fit: cover;
		filter: saturate(0.88) contrast(1.04) brightness(0.92);
		transform: scale(1.015);
	}

	.media-panel__shade {
		z-index: 0;
		background:
			linear-gradient(180deg, rgba(12, 12, 12, 0.34), rgba(12, 12, 12, 0.04) 40%, rgba(12, 12, 12, 0.58)),
			linear-gradient(90deg, rgba(12, 12, 12, 0.42), rgba(12, 12, 12, 0.04) 56%, rgba(12, 12, 12, 0.22));
	}

	.media-panel__shade--craft {
		background:
			linear-gradient(180deg, rgba(12, 12, 12, 0.36), rgba(12, 12, 12, 0.06) 42%, rgba(12, 12, 12, 0.62)),
			linear-gradient(90deg, rgba(12, 12, 12, 0.46), rgba(12, 12, 12, 0.05) 62%);
	}

	.media-panel__content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: end;
		width: min(860px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 9rem 0 clamp(5.25rem, 12vh, 8.5rem);
		text-align: center;
	}

	.media-panel__content--craft {
		align-items: center;
		justify-content: end;
		width: min(780px, calc(100% - 2rem));
		margin: 0 auto;
		text-align: center;
	}

	.kicker {
		margin: 0 0 1.15rem;
		color: rgba(238, 238, 238, 0.78);
		text-transform: uppercase;
		letter-spacing: 0.32em;
		font-size: clamp(0.62rem, 0.72vw, 0.74rem);
		font-weight: 500;
	}

	.kicker--dark {
		color: rgba(238, 238, 238, 0.64);
	}

	h1,
	.media-panel h2,
	.explore h2 {
		margin: 0;
		font-family: var(--font-body);
		font-weight: 300;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}

	h1 {
		max-width: 900px;
		font-size: clamp(1.7rem, 3.1vw, 3.75rem);
		line-height: 1.1;
	}

	.media-panel h2 {
		max-width: 820px;
		font-size: clamp(1.5rem, 2.75vw, 3.25rem);
		line-height: 1.12;
	}

	.scroll-cue {
		cursor: pointer;
		width: 48px;
		height: 48px;
		margin-top: clamp(2rem, 5vw, 4rem);
		color: var(--color-main);
		opacity: 0.78;
		transition:
			opacity 180ms ease,
			transform 180ms ease;
	}

	.scroll-cue span {
		width: 12px;
		height: 12px;
		border-right: 1px solid currentColor;
		border-bottom: 1px solid currentColor;
		transform: rotate(45deg) translate(-2px, -2px);
	}

	.scroll-cue:hover,
	.scroll-cue:focus-visible {
		color: rgba(238, 238, 238, 0.96);
		opacity: 1;
		transform: translateY(4px);
	}

	.scroll-cue:focus-visible,
	.explore-card:focus-visible {
		outline: 1px solid rgba(238, 238, 238, 0.62);
		outline-offset: 0.35rem;
	}

	.section-indicator {
		position: fixed;
		top: 50%;
		left: clamp(1rem, 2vw, 2.5rem);
		z-index: 45;
		display: grid;
		gap: 1.38rem;
		transform: translateY(-50%);
	}

	.section-indicator__dot {
		position: relative;
		display: grid;
		place-items: center;
		width: 22px;
		height: 22px;
		padding: 0;
		color: rgba(238, 238, 238, 0.92);
		background: transparent;
		border: 0;
		cursor: pointer;
	}

	.section-indicator__dot::before,
	.section-indicator__dot::after {
		display: block;
		position: absolute;
		top: 50%;
		left: 50%;
		border-radius: 999px;
		content: '';
		transition:
			background 180ms ease,
			border-color 180ms ease,
			opacity 180ms ease,
			transform 180ms ease;
	}

	.section-indicator__dot::before {
		width: 21px;
		height: 21px;
		border: 2px solid transparent;
		opacity: 0;
		transform: translate(-50%, -50%);
	}

	.section-indicator__dot::after {
		width: 7px;
		height: 7px;
		background: rgba(238, 238, 238, 0.54);
		transform: translate(-50%, -50%);
	}

	.section-indicator__dot.is-active::before,
	.section-indicator__dot:hover::before,
	.section-indicator__dot:focus-visible::before {
		border-color: rgba(238, 238, 238, 0.96);
		opacity: 1;
	}

	.section-indicator__dot.is-active::after,
	.section-indicator__dot:hover::after,
	.section-indicator__dot:focus-visible::after {
		background: rgba(238, 238, 238, 0.96);
		transform: translate(-50%, -50%) scale(0.9);
	}

	.section-indicator__dot span {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
	}

	.section-indicator__dot:focus-visible {
		outline: 0;
	}

	.explore {
		background: #101010;
		color: var(--color-main);
		padding: clamp(7rem, 11vw, 11rem) clamp(1.25rem, 4vw, 4.5rem) clamp(7.5rem, 11vw, 11rem);
	}

	.explore__intro {
		width: min(1500px, 100%);
		margin: 0 auto clamp(3.5rem, 5.6vw, 5.75rem);
		text-align: center;
	}

	.explore h2 {
		font-size: clamp(1.65rem, 2.45vw, 3rem);
		line-height: 1.12;
	}

	.explore-grid {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: clamp(340px, 29vw, 430px);
		gap: clamp(1.1rem, 1.25vw, 1.55rem);
		width: min(1500px, 100%);
		margin: 0 auto;
		overflow-x: auto;
		overflow-y: hidden;
		padding-bottom: 1.1rem;
		scroll-padding-inline: clamp(1.1rem, 1.25vw, 1.55rem);
		scroll-snap-type: x proximity;
		scrollbar-color: rgba(238, 238, 238, 0.32) rgba(238, 238, 238, 0.08);
		scrollbar-width: thin;
	}

	.explore-grid::-webkit-scrollbar {
		height: 2px;
	}

	.explore-grid::-webkit-scrollbar-track {
		background: rgba(238, 238, 238, 0.08);
	}

	.explore-grid::-webkit-scrollbar-thumb {
		background: rgba(238, 238, 238, 0.34);
	}

	.explore-card {
		position: relative;
		display: grid;
		grid-template-rows: auto auto;
		color: var(--color-main);
		text-decoration: none;
		background: #111111;
		border-left: 1px solid rgba(238, 238, 238, 0.36);
		scroll-snap-align: start;
		transition:
			border-color 220ms ease,
			transform 220ms ease,
			opacity 220ms ease;
	}

	.explore-card:hover,
	.explore-card:focus-visible {
		color: rgba(238, 238, 238, 0.96);
		border-color: rgba(238, 238, 238, 0.62);
		transform: translateY(-4px);
	}

	.explore-card__image {
		position: relative;
		display: block;
		aspect-ratio: 1.48;
		min-height: 0;
		overflow: hidden;
		background: #0c0c0c;
	}

	.explore-card__image::after {
		position: absolute;
		inset: 0;
		content: '';
		background:
			linear-gradient(180deg, rgba(10, 10, 10, 0.08), rgba(10, 10, 10, 0.24)),
			linear-gradient(90deg, rgba(10, 10, 10, 0.14), rgba(10, 10, 10, 0.02) 48%, rgba(10, 10, 10, 0.18));
		pointer-events: none;
	}

	.explore-card__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(1.04) contrast(1.04) brightness(0.9);
		transform: scale(1.001);
		transition:
			filter 220ms ease,
			transform 560ms ease;
	}

	.explore-card:hover .explore-card__image img,
	.explore-card:focus-visible .explore-card__image img {
		filter: saturate(1.12) contrast(1.06) brightness(0.98);
		transform: scale(1.028);
	}

	.explore-card__body {
		display: grid;
		align-content: start;
		gap: clamp(0.82rem, 1.1vw, 1.15rem);
		min-height: 206px;
		padding: clamp(1.45rem, 1.7vw, 2rem) clamp(1.35rem, 1.8vw, 2rem) clamp(1.75rem, 2.15vw, 2.4rem);
	}

	.explore-card__meta {
		display: grid;
		grid-template-columns: auto;
		align-items: center;
		width: fit-content;
		color: rgba(238, 238, 238, 0.5);
		font-size: clamp(0.66rem, 0.72vw, 0.76rem);
		font-weight: 300;
		letter-spacing: 0.18em;
	}

	.explore-card__meta span:last-child {
		display: none;
	}

	.explore-card__body strong {
		max-width: 28ch;
		text-transform: uppercase;
		letter-spacing: 0.24em;
		font-size: clamp(0.88rem, 1.05vw, 1.18rem);
		font-weight: 400;
		line-height: 1.46;
		text-wrap: balance;
	}

	.explore-card__text {
		display: block;
		max-width: 42ch;
		color: rgba(238, 238, 238, 0.62);
		font-size: clamp(0.92rem, 1.02vw, 1.06rem);
		font-weight: 300;
		letter-spacing: 0.035em;
		line-height: 1.62;
	}

	.explore-card:nth-child(1) .explore-card__image img {
		object-position: 58% 48%;
	}

	.explore-card:nth-child(2) .explore-card__image img {
		object-position: 50% 42%;
	}

	.explore-card:nth-child(3) .explore-card__image img {
		object-position: 50% 18%;
	}

	.explore-card:nth-child(4) .explore-card__image img {
		object-position: 62% 50%;
	}

	.explore-card:nth-child(5) .explore-card__image img {
		object-position: 46% 54%;
	}

	@supports not (text-wrap: balance) {
		.explore-card__body strong {
			text-wrap: normal;
		}
	}

	@media (max-width: 1180px) {
		.explore-grid {
			grid-auto-columns: clamp(320px, 44vw, 410px);
			gap: clamp(1rem, 2.4vw, 1.75rem);
		}

		.explore-card__image {
			aspect-ratio: 1.52;
		}

		.explore-card__body {
			padding: clamp(1.25rem, 2.8vw, 1.8rem);
		}
	}

	@media (max-width: 980px), (pointer: coarse) {
		.section-indicator {
			display: none;
		}
	}

	@media (max-width: 760px) {
		.media-panel {
			min-height: 100svh;
		}

		.media-panel__content,
		.media-panel__content--craft {
			width: min(100% - 2rem, 560px);
			margin: 0 auto;
			align-items: center;
			justify-content: end;
			padding: 6rem 0 clamp(7.75rem, 18svh, 10rem);
			text-align: center;
		}

		h1 {
			font-size: clamp(1.62rem, 7.4vw, 2.25rem);
			line-height: 1.12;
			letter-spacing: 0.12em;
		}

		.media-panel h2 {
			font-size: clamp(1.48rem, 7vw, 2.05rem);
			line-height: 1.14;
			letter-spacing: 0.12em;
		}

		.scroll-cue {
			margin-top: 1.65rem;
		}

		.explore {
			padding: 5.8rem 1rem 5.5rem;
		}

		.explore__intro {
			text-align: center;
			margin-bottom: 2.6rem;
		}

		.explore h2 {
			font-size: 1.45rem;
		}

		.explore-grid {
			display: grid;
			grid-auto-flow: row;
			grid-auto-columns: unset;
			grid-template-columns: minmax(0, 1fr);
			gap: 1rem;
			width: min(100%, 430px);
			overflow: visible;
			padding-bottom: 0;
			scroll-snap-type: none;
		}

		.explore-card {
			transform: none;
		}

		.explore-card__image {
			aspect-ratio: 1.78;
		}

		.explore-card:hover,
		.explore-card:focus-visible {
			transform: none;
		}

		.explore-card__image::after {
			background:
				linear-gradient(180deg, rgba(9, 9, 9, 0.2), rgba(9, 9, 9, 0.32)),
				linear-gradient(90deg, rgba(9, 9, 9, 0.26), rgba(9, 9, 9, 0.08) 70%);
		}

		.explore-card__body {
			gap: 0.58rem;
			min-height: auto;
			padding: 1.1rem 1rem 1.45rem;
		}

		.explore-card__meta {
			font-size: 0.62rem;
		}

		.explore-card__body strong {
			max-width: 22ch;
			font-size: clamp(0.96rem, 4.55vw, 1.14rem);
			letter-spacing: 0.16em;
			line-height: 1.32;
		}

		.explore-card__text {
			font-size: 1rem;
			letter-spacing: 0.02em;
			line-height: 1.5;
		}
	}
</style>
